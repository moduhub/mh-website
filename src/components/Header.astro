---
const nav = [
  { label: 'Sobre',    href: '/sobre' },
  { label: 'Produtos', href: '/produtos' },
  { label: 'Serviços', href: '/servicos' },
  { label: 'Contato',  href: '/contato' },
];

const pd = [
  { label: 'CRUXRV',    href: '/cruxrv',    desc: 'Microcontrolador RISC-V radio-native' },
  { label: 'Fieldfare', href: '/fieldfare',  desc: 'Redes distribuídas sem autoridade central' },
];

const pathname = Astro.url.pathname;
const pdAtivo = pd.some(item => pathname.startsWith(item.href));
---

<header class="header" id="header">
  <div class="container header__inner">

    <a href="/" class="header__logo">
      <img src="/mh_main_logo.svg" alt="ModuHub Tecnologia" class="header__logo-img" />
    </a>

    <nav class="header__nav" id="nav">
      {nav.map(item => (
        <a
          href={item.href}
          class={`header__link ${pathname.startsWith(item.href) ? 'header__link--ativo' : ''}`}
        >
          {item.label}
        </a>
      ))}

      <!-- Dropdown P&D -->
      <div class={`header__dropdown ${pdAtivo ? 'header__dropdown--ativo' : ''}`} id="pdDropdown">
        <button class="header__link header__dropdown-btn" id="pdBtn" aria-expanded="false">
          P&amp;D <span class="header__dropdown-chevron">▾</span>
        </button>
        <div class="header__dropdown-menu" id="pdMenu">
          {pd.map(item => (
            <a
              href={item.href}
              class={`header__dropdown-item ${pathname.startsWith(item.href) ? 'header__dropdown-item--ativo' : ''}`}
            >
              <span class="header__dropdown-item-label">{item.label}</span>
              <span class="header__dropdown-item-desc">{item.desc}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>

    <a href="/contato" class="btn btn--primario header__cta">Fale conosco</a>

    <button class="header__menu-btn" id="menuBtn" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>

  </div>
</header>

<script>
  const header  = document.getElementById('header');
  const nav     = document.getElementById('nav');
  const menuBtn = document.getElementById('menuBtn');
  const pdBtn      = document.getElementById('pdBtn');
  const pdDropdown = document.getElementById('pdDropdown');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('header--scrolled', window.scrollY > 40);
  });

  menuBtn?.addEventListener('click', () => {
    nav?.classList.toggle('header__nav--aberto');
    menuBtn.classList.toggle('header__menu-btn--ativo');
  });

  // Dropdown toggle
  pdBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = pdDropdown?.classList.toggle('header__dropdown--open');
    pdBtn.setAttribute('aria-expanded', String(open));
  });

  // Fechar ao clicar fora
  document.addEventListener('click', () => {
    pdDropdown?.classList.remove('header__dropdown--open');
    pdBtn?.setAttribute('aria-expanded', 'false');
  });
</script>

<style>
.header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  transition: background 0.3s, border-color 0.3s;
  border-bottom: 1px solid transparent;
}

.header--scrolled {
  background: rgba(10, 13, 15, 0.92);
  backdrop-filter: blur(12px);
  border-bottom-color: var(--cor-borda);
}

.header__inner {
  display: flex;
  align-items: center;
  gap: 2rem;
  height: 72px;
}

.header__logo {
  display: flex;
  align-items: center;
  text-decoration: none;
  flex-shrink: 0;
}

.header__logo-img {
  height: 28px;
  width: auto;
}

.header__nav {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  margin-left: auto;
}

.header__link {
  font-family: var(--fonte-corpo);
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--cor-texto-dim);
  padding: 0.4rem 0.75rem;
  border-radius: 4px;
  transition: color 0.2s, background 0.2s;
  text-decoration: none;
}

.header__link:hover,
.header__link--ativo {
  color: var(--cor-texto);
  background: rgba(255,255,255,0.05);
}

.header__link--ativo { color: var(--cor-primaria); }

/* ── Dropdown ── */
.header__dropdown { position: relative; }

.header__dropdown-btn {
  background: none;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.3rem;
}

.header__dropdown--ativo .header__dropdown-btn {
  color: var(--cor-primaria);
}

.header__dropdown-chevron {
  font-size: 0.65rem;
  transition: transform 0.2s;
  display: inline-block;
}

.header__dropdown--open .header__dropdown-chevron {
  transform: rotate(180deg);
}

.header__dropdown-menu {
  display: none;
  position: absolute;
  top: calc(100% + 0.5rem);
  right: 0;
  min-width: 240px;
  background: var(--cor-fundo-2);
  border: 1px solid var(--cor-borda);
  border-radius: 6px;
  padding: 0.5rem;
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
}

.header__dropdown--open .header__dropdown-menu { display: flex; flex-direction: column; gap: 0.25rem; }

.header__dropdown-item {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  padding: 0.65rem 0.85rem;
  border-radius: 4px;
  text-decoration: none;
  transition: background 0.15s;
}

.header__dropdown-item:hover,
.header__dropdown-item--ativo {
  background: rgba(255,255,255,0.06);
}

.header__dropdown-item-label {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--cor-texto);
}

.header__dropdown-item--ativo .header__dropdown-item-label {
  color: var(--cor-primaria);
}

.header__dropdown-item-desc {
  font-size: 0.75rem;
  color: var(--cor-texto-muted);
}

/* ── CTA e menu mobile ── */
.header__cta {
  flex-shrink: 0;
  font-size: 0.82rem;
  padding: 0.55rem 1.2rem;
}

.header__menu-btn {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}

.header__menu-btn span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--cor-texto-dim);
  transition: all 0.2s;
}

@media (max-width: 900px) {
  .header__nav {
    display: none;
    position: fixed;
    top: 72px; left: 0; right: 0;
    flex-direction: column;
    align-items: flex-start;
    background: var(--cor-fundo-2);
    border-bottom: 1px solid var(--cor-borda);
    padding: 1.5rem 2rem;
    gap: 0.25rem;
    margin-left: 0;
  }

  .header__nav--aberto { display: flex; }

  .header__link { width: 100%; padding: 0.6rem 0.75rem; }

  /* Dropdown mobile: sempre expandido dentro do menu */
  .header__dropdown { width: 100%; }
  .header__dropdown-btn { width: 100%; padding: 0.6rem 0.75rem; }
  .header__dropdown-menu {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: static;
    background: none;
    border: none;
    box-shadow: none;
    padding: 0 0 0 1rem;
    min-width: unset;
  }
  .header__dropdown--open .header__dropdown-menu,
  .header__dropdown-menu { display: flex; } /* sempre visível no mobile */
  .header__dropdown-chevron { display: none; }

  .header__cta { display: none; }
  .header__menu-btn { display: flex; margin-left: auto; }
}
</style>
