---
import Base from '../layouts/Base.astro';
---

<Base title="Página não encontrada" description="Página não encontrada.">
  <section style="min-height:80vh; display:flex; align-items:center">
    <div class="container" style="text-align:center">
      <div style="font-family:var(--fonte-display); font-size:8rem; font-weight:800; color:var(--cor-borda); line-height:1">404</div>
      <h1 style="margin-bottom:1rem">Página não encontrada</h1>
      <p style="margin-bottom:2rem">O endereço que você acessou não existe ou foi movido.</p>
      <a href="/" class="btn btn--primario">Voltar ao início</a>
    </div>
  </section>
</Base>
