---
import Base from '../layouts/Base.astro';

const produtos = [
  {
    id: 'medidor-energia-portatil',
    nome: 'Medidor de Energia Portátil',
    subtitulo: 'Verificação de instalações em distribuidoras de energia',
    segmento: 'Energia',
    status: 'Comercializado',
    statusTipo: 'acento',
    descricao: 'Dispositivo portátil para verificação de instalações e medidores de energia elétrica em campo, desenvolvido para distribuidoras. Fornecido à CELESC Distribuição S.A. com aprovação por inspeção técnica da Divisão de Controle de Qualidade.',
    specs: [
      'Atende NBR 14519, NBR 14522 e UL 94',
      'Indutores bipartidos de projeto interno',
      'Conectividade sem fio embarcada',
      'Aprovado por inspeção técnica CELESC',
    ],
    destaque: 'CELESC Distribuição — 180 unidades — R$ 296.100',
    patente: false,
  },
  {
    id: 'openafe',
    nome: 'OpenAFE — Potenciostato',
    subtitulo: 'Plataforma de fonte aberta para biossensores',
    segmento: 'Saúde',
    status: 'Lote disponível',
    statusTipo: 'primario',
    descricao: 'Front-end analógico de precisão para análises eletroquímicas e espectroscopia de impedância. Plataforma open-source para desenvolvimento de biossensores eletroquímicos.',
    specs: [
      'Operação em escala de nanoampère',
      'Geração de formas de onda controladas',
      'Eletrodos em PCB com tratamento de superfície',
      'Interface gráfica Python/React',
    ],
    destaque: 'Subvenção FAPESC CP 08/2024 — Programa Mulheres+TEC',
    patente: false,
  },
  {
    id: 'btcore',
    nome: 'Módulo btcore',
    subtitulo: 'Hardware para redes distribuídas de campo',
    segmento: 'IoT',
    status: 'Disponível',
    statusTipo: 'primario',
    descricao: 'Módulo de hardware compacto integrando funções fundamentais para sensores e nós intermediários em redes distribuídas, principalmente para aplicações de campo.',
    specs: [
      'Processador nRF52840 com rádio 2,4 GHz e módulo criptográfico',
      'Rádio 915 MHz com front-end RF até 500 mW',
      'Antenas cerâmicas 2,4 GHz e 915 MHz embutidas',
      '1 GB em memória Flash NAND',
      'Tamanho reduzido: 30 × 32 mm',
      'Pinos castelados para montagem em SMD',
    ],
    destaque: 'Sob encomenda — contato: contato@moduhub.com',
    patente: false,
  },
];
---

<Base
  title="Produtos"
  description="Produtos ModuHub: Medidor de Energia Portátil (fornecido à CELESC), potenciostato OpenAFE, módulo btcore para IoT e biblioteca Fieldfare para redes distribuídas."
  canonical="/produtos"
>

  <div class="page-hero">
    <div class="container">
      <span class="label-secao">Portfólio</span>
      <h1>Produtos com engenharia<br/>inteiramente nacional</h1>
      <p class="page-hero__desc">
        Da instrumentação de energia a biossensores — produtos concebidos e desenvolvidos
        internamente, validados comercialmente em campo.
      </p>
    </div>
  </div>

  <section>
    <div class="container">
      <div class="produtos__lista">
        {produtos.map((p, i) => (
          <div class={`card produto__card ${i === 0 ? 'produto__card--destaque' : ''}`}>
            <div class="produto__header">
              <div>
                <div class="produto__meta">
                  <span class="tag">{p.segmento}</span>
                  <span class={`tag tag--${p.statusTipo}`}>{p.status}</span>
                  {p.patente && <span class="tag">Patente submetida</span>}
                </div>
                <h2 class="produto__nome">{p.nome}</h2>
                <p class="produto__subtitulo">{p.subtitulo}</p>
              </div>
              <div class="produto__foto-placeholder">
                {/* FOTO: imagem do produto {p.id} */}
                <span class="produto__foto-label">{p.nome.substring(0, 2).toUpperCase()}</span>
              </div>
            </div>

            <p class="produto__desc">{p.descricao}</p>

            <div class="produto__specs">
              <h4>Especificações</h4>
              <ul>
                {p.specs.map(s => <li>{s}</li>)}
              </ul>
            </div>

            <div class="produto__rodape">
              <div class="produto__destaque">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                {p.destaque}
              </div>
              <a href="/contato" class="btn btn--outline btn--sm">Solicitar informações →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


</Base>

<style>
.page-hero {
  padding: 10rem 0 5rem;
  background: linear-gradient(180deg, rgba(0,194,255,0.05) 0%, transparent 100%);
  border-bottom: 1px solid var(--cor-borda);
}
.page-hero__desc { max-width: 600px; font-size: 1.1rem; margin-top: 1.25rem; }

.produtos__lista {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  padding: 1rem 0;
}

.produto__card { transition: border-color 0.2s, transform 0.2s; }
.produto__card--destaque {
  border-color: var(--cor-primaria-dim);
  background: rgba(0,194,255,0.03);
}

.produto__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 2rem;
  margin-bottom: 1.25rem;
}

.produto__meta {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 0.75rem;
}

.produto__nome {
  font-size: 1.6rem;
  margin-bottom: 0.25rem;
}

.produto__subtitulo {
  font-family: var(--fonte-mono);
  font-size: 0.8rem;
  color: var(--cor-texto-muted);
  margin: 0;
}

.produto__foto-placeholder {
  width: 120px; height: 120px;
  border-radius: 8px;
  background: var(--cor-fundo);
  border: 1px solid var(--cor-borda);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  /* FOTO: substituir pelo <img> do produto */
}

.produto__foto-label {
  font-family: var(--fonte-display);
  font-size: 1.8rem;
  font-weight: 800;
  color: var(--cor-texto-muted);
}

.produto__desc {
  margin-bottom: 1.5rem;
  font-size: 1rem;
}

.produto__specs {
  background: var(--cor-fundo);
  border: 1px solid var(--cor-borda);
  border-radius: 4px;
  padding: 1.25rem;
  margin-bottom: 1.5rem;
}

.produto__specs h4 {
  font-family: var(--fonte-mono);
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--cor-texto-muted);
  margin-bottom: 0.75rem;
}

.produto__specs ul {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 0.4rem;
}

.produto__specs li {
  font-size: 0.88rem;
  color: var(--cor-texto-dim);
  padding-left: 1.25rem;
  position: relative;
}

.produto__specs li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--cor-primaria);
}

.produto__rodape {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
  padding-top: 1.25rem;
  border-top: 1px solid var(--cor-borda);
}

.produto__destaque {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--fonte-mono);
  font-size: 0.8rem;
  color: var(--cor-acento);
}

.btn--sm {
  font-size: 0.82rem;
  padding: 0.5rem 1rem;
}

@media (max-width: 600px) {
  .produto__header { flex-direction: column-reverse; }
  .produto__foto-placeholder { width: 80px; height: 80px; }
}
</style>
